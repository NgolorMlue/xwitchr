# ============================================================
# API Key Router - Environment Configuration
# ============================================================
#
# ⚠️  IMPORTANT: This file is only used for INITIAL SEEDING on first run.
#     Once the server starts, all configuration is persisted to config.json
#     and managed through the web dashboard at /dashboard (Settings tab).
#     Changes made here after first run will NOT take effect.
#
# To get started: copy this file to .env and fill in your values.
# ============================================================

# --- Server ---
PORT=3000

# A secret token your team uses to call THIS proxy
PROXY_AUTH_TOKEN=your-shared-team-secret-token-here

# --- Dashboard Security ---
# Credentials for unlocking the web UI at /dashboard
# Passwords will be securely hashed with scrypt and stored in config.json on first boot
# If left blank, a random password will be auto-generated and logged to the console
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-secure-dashboard-admin-password

# --- Quota Settings ---
# Switch to next key when a key hits this many requests per minute
ROTATION_THRESHOLD=32
# Hard limit per key per minute (for reference)
MAX_REQUESTS_PER_MINUTE=35

# --- Key Injection ---
# How to send the API key to the upstream API
# Options: 'query' | 'header' | 'bearer'
KEY_INJECT_MODE=query

# If KEY_INJECT_MODE=query, the query param name to use (e.g. ?api_key=...)
KEY_INJECT_PARAM=api_key

# If KEY_INJECT_MODE=header, the header name to use (e.g. X-API-Key: ...)
KEY_INJECT_HEADER=X-API-Key
